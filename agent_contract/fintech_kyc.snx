library FintechKyc {
  fn verifyIdentity(check: IdentityCheck): Event {
    try {
      require(
        check.cpf != "";
        Error("MISSING_CPF", "CPF é obrigatório")
      )
      require(
        check.age >= FintechPolicy.minAge;
        Error("UNDER_AGE", "Idade abaixo do mínimo permitido")
      )
      require(
        check.faceMatchScore <= 100;
        Error("INVALID_SCORE", "faceMatchScore inválido")
      )
      require(
        check.documentScore <= 100;
        Error("INVALID_SCORE", "documentScore inválido")
      )

      let blocked = 0
      for (i = 0; i < len(FintechPolicy.blockedCpfs); i = i + 1) {
        if (FintechPolicy.blockedCpfs[i] == check.cpf) {
          blocked = 1
        }
      }
      require(
        blocked == 0;
        Error("CPF_BLOCKED", "CPF na lista de bloqueio")
      )

      const totalScore = (check.faceMatchScore + check.documentScore) / 2
      const verificationId = hash("SHA256", check.client, check.cpf, check.age)

      emit("IdentityVerified", {
        client: check.client,
        cpf: check.cpf,
        age: check.age,
        totalScore: totalScore,
        nonce: verificationId
      })
    } catch (err) {
      const rejections = {
        MISSING_CPF:   { client: check.client, reason: "missing_cpf" },
        UNDER_AGE:     { client: check.client, cpf: check.cpf, age: check.age, reason: "under_minimum_age" },
        INVALID_SCORE: { client: check.client, cpf: check.cpf, reason: "invalid_score" },
        CPF_BLOCKED:   { client: check.client, cpf: check.cpf, reason: "cpf_blocked" }
      }
      const entry = rejections[err.code]
      if (entry == null) {
        emit("IdentityVerificationRejected", {
          client: check.client,
          cpf: check.cpf,
          reason: "unknown_error",
          message: err.message
        })
      } else {
        emit("IdentityVerificationRejected", entry)
      }
    }
  }

  fn recordKycLevel(result: KycResult): Event {
    try {
      require(
        result.totalScore <= 100;
        Error("INVALID_SCORE", "totalScore deve ser entre 0 e 100")
      )

      const recordHash = hash("SHA256", result.client, result.cpf, result.totalScore)

      if (result.totalScore >= FintechPolicy.kycFullMinScore) {
        emit("KycLevelAssigned", {
          client: result.client,
          cpf: result.cpf,
          level: "full",
          totalScore: result.totalScore,
          nonce: recordHash
        })
      } else if (result.totalScore >= FintechPolicy.kycBasicMinScore) {
        emit("KycLevelAssigned", {
          client: result.client,
          cpf: result.cpf,
          level: "basic",
          totalScore: result.totalScore,
          nonce: recordHash
        })
      } else {
        emit("KycLevelRejected", {
          client: result.client,
          cpf: result.cpf,
          totalScore: result.totalScore,
          reason: "score_below_basic"
        })
      }
    } catch (err) {
      const rejections = {
        INVALID_SCORE: { client: result.client, cpf: result.cpf, reason: "invalid_total_score" }
      }
      const entry = rejections[err.code]
      if (entry == null) {
        emit("KycLevelRejected", {
          client: result.client,
          cpf: result.cpf,
          reason: "unknown_error",
          message: err.message
        })
      } else {
        emit("KycLevelRejected", entry)
      }
    }
  }
}
